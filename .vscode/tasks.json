{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "🌿 Start Carbon API",
      "type": "shell",
      "command": ".venv/Scripts/python.exe -m uvicorn src.api.carbon_api:app --reload --port 8000",
      "options": { "cwd": "${workspaceFolder}" },
      "group": { "kind": "build", "isDefault": true },
      "presentation": { "reveal": "always", "panel": "new" },
      "problemMatcher": []
    },
    {
      "label": "🌐 Open Carbon UI in browser",
      "type": "shell",
      "command": "start ui/carbon/index.html",
      "options": { "cwd": "${workspaceFolder}" },
      "presentation": { "reveal": "silent" },
      "problemMatcher": []
    },
    {
      "label": "📦 Install / upgrade requirements",
      "type": "shell",
      "command": ".venv/Scripts/pip.exe install -r requirements.txt --upgrade",
      "options": { "cwd": "${workspaceFolder}" },
      "presentation": { "reveal": "always", "panel": "shared" },
      "problemMatcher": []
    },
    {
      "label": "📦 Install FastAPI + uvicorn",
      "type": "shell",
      "command": ".venv/Scripts/pip.exe install fastapi uvicorn[standard] python-multipart",
      "options": { "cwd": "${workspaceFolder}" },
      "presentation": { "reveal": "always", "panel": "shared" },
      "problemMatcher": []
    }
  ]
}
